#!/bin/bash
#SBATCH --output=out.%j
#SBATCH --error=err.%j
#SBATCH --time=00-23:59:59        # walltime
#SBATCH --cpus-per-task=4    # number of processor cores (i.e. tasks)
#SBATCH --partition=kr
                  # additional dist options (specified via runscript setting)

# Good Idea to stop operation on first error.
set -e

# Load environment modules for your application here.
source ~/.bashrc

# Run jobs
jobs="results/sokoban/telingo-1-default/instances/sokoban/0428-sokoban-120-1/run1/start.sh
results/sokoban/telingo-1-default/instances/sokoban/0096-sokoban-36-1/run1/start.sh
results/sokoban/telingo-1-default/instances/sokoban/0516-sokoban-200-1/run1/start.sh
results/sokoban/telingo-1-default/instances/sokoban/0128-sokoban-131-1/run1/start.sh
results/visitall/telingo-1-default/instances/visitall/0012-visitall-36-1/run1/start.sh
results/visitall/telingo-1-default/instances/visitall/0031-visitall-39-1/run1/start.sh
results/visitall/telingo-1-default/instances/visitall/0089-visitall-66-1/run1/start.sh
results/visitall/telingo-1-default/instances/visitall/0070-visitall-49-1/run1/start.sh
results/visitall/telingo-1-default/instances/visitall/0029-visitall-39-1/run1/start.sh
results/visitall/telingo-1-default/instances/visitall/0071-visitall-49-1/run1/start.sh
results/visitall/telingo-1-default/instances/visitall/0030-visitall-39-1/run1/start.sh
results/visitall/telingo-1-default/instances/visitall/0009-visitall-36-1/run1/start.sh
"
echo running jobs@$(hostname)...
echo ""
echo "jobs:" $jobs
echo ""
for i in $jobs
do
    echo "running " $i
    $i
done
