<runscript output="output-del-telingo">

	<machine name="houat" cpu="8xE5520@2.27GHz" memory="24GB"/>

	<config name="seq-generic" template="templates/seq-generic.sh"/>
	<system name="telingo" version="1" measures="rp_tmp" config="seq-generic" cmdline="--stats 0 -q">
		<setting name="default"  cmdline="" tag="del"/>
	</system>


	<distjob name="dist-generic" timeout="1200s" runs="1" template_options="--single"
		script_mode="timeout" walltime="23h 59m 59s" cpt="4" />


	<benchmark name="elevator">
		<files path="instances/del">
			<encoding file="instances/del/elevator-telingo.lp"/>
			<encoding file="instances/del/elevator-telingo-control.lp"/>
			<add file="instances/f5-n8.lp" cmdline="--lambd=8"/>
			<add file="instances/f5-n9.lp" cmdline="--lambd=9"/>
			<add file="instances/f5-n10.lp" cmdline="--lambd=10"/>
			<add file="instances/f5-n11.lp" cmdline="--lambd=11"/>
			<add file="instances/f5-n12.lp" cmdline="--lambd=12"/>
			<add file="instances/f7-n11.lp" cmdline="--lambd=11"/>
			<add file="instances/f7-n12.lp" cmdline="--lambd=12"/>
			<add file="instances/f7-n13.lp" cmdline="--lambd=13"/>
			<add file="instances/f7-n14.lp" cmdline="--lambd=14"/>
			<add file="instances/f7-n15.lp" cmdline="--lambd=15"/>
			<add file="instances/f9-n14.lp"	 cmdline="--lambd=14"/>
			<add file="instances/f9-n15.lp"  cmdline="--lambd=15"/>
			<add file="instances/f9-n16.lp"  cmdline="--lambd=16"/>
			<add file="instances/f9-n17.lp"  cmdline="--lambd=17"/>
			<add file="instances/f9-n18.lp"  cmdline="--lambd=18"/>
			<add file="instances/f11-n17.lp" cmdline="--lambd=17"/>
			<add file="instances/f11-n18.lp" cmdline="--lambd=18"/>
			<add file="instances/f11-n19.lp" cmdline="--lambd=19"/>
			<add file="instances/f11-n20.lp" cmdline="--lambd=20"/>
			<add file="instances/f11-n21.lp" cmdline="--lambd=21"/>
		</files>
	</benchmark>


	<benchmark name="elevator-no-control">
		<files path="instances/del">
			<encoding file="instances/del/elevator-telingo.lp"/>
			<add file="instances/f5-n8.lp" cmdline="--lambd=8"/>
			<add file="instances/f5-n9.lp" cmdline="--lambd=9"/>
			<add file="instances/f5-n10.lp" cmdline="--lambd=10"/>
			<add file="instances/f5-n11.lp" cmdline="--lambd=11"/>
			<add file="instances/f5-n12.lp" cmdline="--lambd=12"/>
			<add file="instances/f7-n11.lp" cmdline="--lambd=11"/>
			<add file="instances/f7-n12.lp" cmdline="--lambd=12"/>
			<add file="instances/f7-n13.lp" cmdline="--lambd=13"/>
			<add file="instances/f7-n14.lp" cmdline="--lambd=14"/>
			<add file="instances/f7-n15.lp" cmdline="--lambd=15"/>
			<add file="instances/f9-n14.lp"	 cmdline="--lambd=14"/>
			<add file="instances/f9-n15.lp"  cmdline="--lambd=15"/>
			<add file="instances/f9-n16.lp"  cmdline="--lambd=16"/>
			<add file="instances/f9-n17.lp"  cmdline="--lambd=17"/>
			<add file="instances/f9-n18.lp"  cmdline="--lambd=18"/>
			<add file="instances/f11-n17.lp" cmdline="--lambd=17"/>
			<add file="instances/f11-n18.lp" cmdline="--lambd=18"/>
			<add file="instances/f11-n19.lp" cmdline="--lambd=19"/>
			<add file="instances/f11-n20.lp" cmdline="--lambd=20"/>
			<add file="instances/f11-n21.lp" cmdline="--lambd=21"/>
		</files>
	</benchmark>

	<project name="telingo-del-all" job="dist-generic">
		<runtag machine="houat" benchmark="elevator"/>
		<runtag machine="houat" benchmark="elevator-no-control"/>
	</project>

</runscript>
